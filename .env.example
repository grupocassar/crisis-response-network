# Project ref (parte del URL, sin https://)
SUPABASE_PROJECT_REF=mtbtgkzwaukqkayxfwqn

# Anon key (pública, ok en código frontend)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im10YnRna3p3YXVrcWtheXhmd3FuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIzNTMzMzUsImV4cCI6MjA5NzkyOTMzNX0.Hhm8kNtc5AU9mg37n8bAT2W7iA9HnaK4KD5F69vYkdI

# Service role key — SECRETA, solo para scripts de servidor/migración
# Supabase Dashboard > Project Settings > API > service_role
