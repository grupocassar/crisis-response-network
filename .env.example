SUPABASE_ACCESS_TOKEN=tu_access_token_aqui

# ── BASE DE DATOS DIRECTA (psql) ──────────────────────────────────────
# Supabase Dashboard > Project Settings > Database > Connection string
# Usar "Session mode" (puerto 5432) para scripts locales
